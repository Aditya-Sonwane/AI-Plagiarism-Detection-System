# Copy this file to .env and adjust as needed.
# All variables are prefixed with PLAG_ and map 1:1 to backend/config.py::Settings

PLAG_ENVIRONMENT=development
PLAG_LOG_LEVEL=INFO

# Embeddings
PLAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
PLAG_EMBEDDING_DIM=384
PLAG_USE_GPU_IF_AVAILABLE=true

# Retrieval
PLAG_TOP_K=5
PLAG_SIMILARITY_THRESHOLD=0.55
PLAG_USE_HYBRID_RETRIEVAL=true
PLAG_USE_CROSS_ENCODER_RERANK=true

# LLM provider: ollama | openai | none
PLAG_LLM_PROVIDER=ollama
PLAG_OLLAMA_BASE_URL=http://localhost:11434
PLAG_OLLAMA_MODEL=llama3

# Only needed if PLAG_LLM_PROVIDER=openai
PLAG_OPENAI_API_KEY=
PLAG_OPENAI_MODEL=gpt-4o-mini
